                            <Label Content="{utils:Localize KeyPath=Language.Tab}"
                                    x:Name="Label_Language"
                                    Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="ComboBox_Language"
                                    Margin="0,0,0,16"
                                    Style="{StaticResource LanguageComboBox}"/>
