                                    Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="ComboBox_PromptLanguage"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource LanguageComboBox}"/>
                            <TextBlock x:Name="TextBlock_PromptLanguageTooltip"
